"""
数据手册 RAG 助手后端服务
基于检索增强生成(RAG)技术，智能阅读嵌入式芯片数据手册
支持文档导出功能
"""
import os
import re
import json
import math
import time
import requests
from datetime import datetime
from docx import Document
from docx.shared import Pt, RGBColor
from docx.enum.text import WD_ALIGN_PARAGRAPH
from typing import List, Dict, Optional, Tuple

# 配置
DATASHEET_DIR = 'datasheets'
INDEX_DIR = 'datasheet_index'
DATASHEET_OUTPUT = 'datasheet_outputs'
os.makedirs(DATASHEET_DIR, exist_ok=True)
os.makedirs(INDEX_DIR, exist_ok=True)
os.makedirs(DATASHEET_OUTPUT, exist_ok=True)


class SimpleTextEmbedder:
    """简单的文本嵌入器（基于关键词频率）"""
    def __init__(self):
        self.vocab = {}
        self.vocab_size = 0

    def _tokenize(self, text: str) -> List[str]:
        """简单分词"""
        text = re.sub(r'[^\w\s]', ' ', text.lower())
        return text.split()

    def _build_vocab(self, texts: List[str]):
        """构建词表"""
        word_freq = {}
        for text in texts:
            tokens = self._tokenize(text)
            for token in tokens:
                if len(token) > 2:
                    word_freq[token] = word_freq.get(token, 0) + 1

        sorted_words = sorted(word_freq.items(), key=lambda x: x[1], reverse=True)
        self.vocab = {word: i for i, (word, _) in enumerate(sorted_words[:5000])}
        self.vocab_size = len(self.vocab)

    def embed(self, text: str) -> List[float]:
        """生成嵌入向量"""
        if not self.vocab:
            return [0.0] * 128

        tokens = self._tokenize(text)
        vector = [0.0] * min(self.vocab_size, 128)

        for token in tokens:
            if token in self.vocab and self.vocab[token] < 128:
                vector[self.vocab[token]] += 1

        # 归一化
        norm = math.sqrt(sum(x * x for x in vector))
        if norm > 0:
            vector = [x / norm for x in vector]

        return vector

    def compute_similarity(self, vec1: List[float], vec2: List[float]) -> float:
        """计算余弦相似度"""
        dot_product = sum(a * b for a, b in zip(vec1, vec2))
        norm1 = math.sqrt(sum(a * a for a in vec1))
        norm2 = math.sqrt(sum(b * b for b in vec2))
        if norm1 == 0 or norm2 == 0:
            return 0.0
        return dot_product / (norm1 * norm2)


class DatasheetRAG:
    """数据手册 RAG 引擎"""

    def __init__(self):
        self.documents = []
        self.embedder = SimpleTextEmbedder()
        self.current_file = None
        self.current_chip = None

    def _extract_text_from_simple(self, file_path: str) -> str:
        """从PDF提取文本（简化版本）"""
        try:
            import pdfplumber
            text_parts = []
            with pdfplumber.open(file_path) as pdf:
                for page in pdf.pages:
                    text = page.extract_text()
                    if text:
                        text_parts.append(text)
            return '\n'.join(text_parts)
        except ImportError:
            return self._generate_demo_content(file_path)

    def _generate_demo_content(self, file_path: str) -> str:
