        return """
        Generic Chip Datasheet
        This is a generic chip datasheet template.
        """

    def _chunk_text(self, text: str, chunk_size: int = 500, overlap: int = 50) -> List[str]:
        """将文本分割成重叠的块"""
        paragraphs = text.split('\n\n')
        chunks = []
        current_chunk = []

        for para in paragraphs:
            para = para.strip()
            if not para:
                continue

            current_text = '\n'.join(current_chunk)
            if len(current_text) + len(para) > chunk_size and current_chunk:
                chunks.append(current_text)
                current_chunk = [current_chunk[-1], para]
            else:
                current_chunk.append(para)

        if current_chunk:
            chunks.append('\n'.join(current_chunk))

        return chunks

    def _extract_metadata(self, text: str) -> Dict:
        """从文本中提取元数据"""
        metadata = {
            'chip_name': 'Unknown',
            'category': 'Unknown',
            'specs': {}
        }

        chip_patterns = [
            r'(STM32[FP]\w+)',
            r'(ESP32[-\w]+)',
            r'(ATmega\d+)',
            r'(PIC\d+\w+)',
            r'(LM\d+)',
            r'(TPS\d+)',
        ]

        for pattern in chip_patterns:
            match = re.search(pattern, text, re.IGNORECASE)
            if match:
                metadata['chip_name'] = match.group(1)
                break

        spec_patterns = {
            'voltage': r'(\d+\.?\d*)V',
            'frequency': r'(\d+)\s*MHz',
            'current': r'(\d+)\s*mA',
            'resolution': r'(\d+)-bit',
        }

        for spec_name, pattern in spec_patterns.items():
            match = re.search(pattern, text, re.IGNORECASE)
            if match:
                metadata['specs'][spec_name] = match.group(1)

        return metadata

    def load_document(self, file_path: str) -> Dict:
        """加载并索引文档"""
        filename = os.path.basename(file_path)
        self.current_file = filename

        text = self._extract_text_from_simple(file_path)
        chunks = self._chunk_text(text)
        new_docs = []

        for i, chunk in enumerate(chunks):
            doc = {
                'id': f'{filename}_{i}',
                'content': chunk,
                'metadata': self._extract_metadata(chunk),
                'chunk_index': i,
                'source': filename
            }
            new_docs.append(doc)

        existing_sources = set(d.get('source') for d in self.documents)
        self.documents = [d for d in self.documents if d.get('source') != filename]
        self.documents.extend(new_docs)

        self.embedder._build_vocab([d['content'] for d in self.documents])
        for doc in self.documents:
            doc['embedding'] = self.embedder.embed(doc['content'])

        self._save_index()

        return {
            'filename': filename,
            'chunks': len(chunks),
            'metadata': self._extract_metadata(text),
            'total_chunks': len(self.documents)
        }

    def _save_index(self):
        """保存索引到磁盘"""
        index_file = os.path.join(INDEX_DIR, 'current_index.json')
        index_data = {
            'current_file': self.current_file,
            'documents': [
                {k: v for k, v in d.items() if k != 'embedding'}
                for d in self.documents
            ]
        }
        os.makedirs(INDEX_DIR, exist_ok=True)
        with open(index_file, 'w', encoding='utf-8') as f:
            json.dump(index_data, f, ensure_ascii=False, indent=2)

    def _load_index(self, filename: str) -> bool:
        """加载索引"""
        index_file = os.path.join(INDEX_DIR, f'{filename}.json')
        if not os.path.exists(index_file):
            return False

        try:
            with open(index_file, 'r', encoding='utf-8') as f:
                index_data = json.load(f)

            self.documents = index_data['documents']
            for doc in self.documents:
                doc['embedding'] = self.embedder.embed(doc['content'])

            self.current_file = filename
            return True
        except Exception as e:
            print(f'加载索引失败: {e}')
            return False

    def retrieve(self, query: str, top_k: int = 3) -> List[Dict]:
        """检索相关文档块"""
        if not self.documents:
            return []

        query_lower = query.lower()
        query_words = set(re.findall(r'\w+', query_lower))

        results = []
        for doc in self.documents:
            content_lower = doc['content'].lower()
            content_words = set(re.findall(r'\w+', content_lower))

            overlap = len(query_words & content_words)
            keyword_score = overlap / max(len(query_words), 1)

            if 'embedding' not in doc:
                doc['embedding'] = self.embedder.embed(doc['content'])
            embed_score = self.embedder.compute_similarity(
                self.embedder.embed(query),
                doc['embedding']
            )

            combined_score = keyword_score * 0.7 + embed_score * 0.3

            chip_keywords = ['stm32', 'esp32', 'lm358', 'atmega', 'pic', 'tps', 'lm']
            for chip in chip_keywords:
                if chip in query_lower and chip in content_lower:
                    combined_score += 0.3
                    break

            results.append({
                'content': doc['content'],
                'metadata': doc.get('metadata', {}),
                'score': combined_score,
                'source': doc.get('source', '')
            })

        results.sort(key=lambda x: x['score'], reverse=True)
        return results[:top_k]

    def ask(self, question: str, model: str = '') -> Dict:
        """使用RAG回答问题（优先RAG，fallback到LLM）"""
        # 1. 先尝试 RAG 检索
        relevant_docs = self.retrieve(question)

        if relevant_docs:
            # 有RAG数据，用RAG回答
            context = '\n\n'.join([doc['content'] for doc in relevant_docs])
            answer = self._generate_answer(question, context, relevant_docs)
            return {
                'content': answer,
                'source': relevant_docs[0]['metadata'].get('chip_name', '数据手册')
            }

        # 2. 没有上传PDF时，fallback到LLM回答（这样始终有消息内容）
        try:
            from dotenv import load_dotenv
            load_dotenv()
        except:
            pass

        API_KEY = os.getenv('DEEPSEEK_KEY')
        API_URL = os.getenv('DEEPSEEK_URL')

        if API_KEY and API_URL:
            import requests
            headers = {
                "Authorization": f"Bearer {API_KEY}",
                "Content-Type": "application/json"
            }
            payload = {
                "model": "",
                "messages": [
                    {"role": "system", "content": "你是一个专业的嵌入式系统工程师，擅长回答单片机、芯片、嵌入式开发相关问题。回答要专业、简洁、有技术深度。"},
                    {"role": "user", "content": question}
                ],
                "temperature": 0.7
            }
            try:
                resp = requests.post(API_URL, headers=headers, json=payload, timeout=60)
                result = resp.json()
                if "choices" in result and len(result["choices"]) > 0:
                    llm_answer = result["choices"][0]["message"]["content"].strip()
                    return {
                        'content': llm_answer,
                        'source': '嵌入式助手'
                    }
            except Exception as e:
                print(f"LLM调用失败: {e}")
                pass

        # 3. 连API都失败了，返回友好提示
        return {
            'content': '抱歉，没有找到相关的文档内容，也没有连接到AI服务。\n\n请尝试：\n1. 上传数据手册PDF文件\n2. 检查后端服务是否正常运行\n3. 确认 .env 中的 API 配置正确',
            'source': None
        }

    def _generate_answer(self, question: str, context: str, relevant_docs: List[Dict]) -> str:
        """生成回答"""
        question_lower = question.lower()
        answer_parts = []

        if 'adc' in question_lower or '分辨率' in question_lower or '采样' in question_lower:
            for doc in relevant_docs:
                content = doc['content']
                content_lower = content.lower()
                if 'adc' in content_lower or 'resolution' in content_lower or '采样' in content_lower:
                    for line in content.split('\n'):
                        if 'resolution' in line.lower() or '12-bit' in line or 'bit' in line.lower():
                            if any(x in line.lower() for x in ['adc', 'resolution', 'sampling']):
                                answer_parts.append(line.strip())

        elif 'gpio' in question_lower or '引脚' in question_lower or '电流' in question_lower:
            for doc in relevant_docs:
                content = doc['content']
                content_lower = content.lower()
                if 'gpio' in content_lower or 'pin' in content_lower or 'output current' in content_lower:
                    for line in content.split('\n'):
                        if 'current' in line.lower() or 'output' in line.lower():
                            if any(x in line.lower() for x in ['ma', 'gpio', 'output']):
                                answer_parts.append(line.strip())

        elif 'i2c' in question_lower or 'uart' in question_lower or 'spi' in question_lower:
            for doc in relevant_docs:
                content = doc['content']
                content_lower = content.lower()
                if 'i2c' in content_lower:
                    for line in content.split('\n'):
                        if 'i2c' in line.lower() or 'speed' in line.lower() or 'khz' in line.lower():
                            answer_parts.append(line.strip())

        elif '功耗' in question_lower or 'power' in question_lower or '电流' in question_lower:
            for doc in relevant_docs:
                content = doc['content']
                content_lower = content.lower()
                if 'power' in content_lower or 'current' in content_lower or 'ma' in content_lower:
                    for line in content.split('\n'):
                        if 'mode' in line.lower() or 'ma' in line.lower() or 'μa' in line.lower():
                            answer_parts.append(line.strip())

        if answer_parts:
            answer = '\n\n'.join(answer_parts[:2])
            answer += f"\n\n📖 信息来源：数据手册相关内容"
            return answer

        summary = "根据数据手册内容，以下信息可能相关：\n\n"
        for i, doc in enumerate(relevant_docs[:2], 1):
            content_preview = doc['content'][:300].replace('\n', ' ')
            summary += f"{i}. {content_preview}...\n\n"
        summary += "📖 信息来源：数据手册（基于语义检索）"
        return summary

    # ============ 文档导出功能 ============

    def export_to_document(self, question: str, answer: str, format: str = "docx") -> Dict:
        """
        将问答结果导出为文档
        format: 'docx' 或 'md'
        """
        timestamp = int(time.time())
        chip_name = self.current_file or "Unknown"

        if format == "md":
            filename = f"数据手册问答_{chip_name}_{timestamp}.md"
            filepath = os.path.join(DATASHEET_OUTPUT, filename)

            md_content = f"""# {chip_name} - 技术问答

> 问题时间：{datetime.now().strftime('%Y-%m-%d %H:%M')}

---

## 问题
{question}

---

## 回答
{answer}

---

## 相关文档信息

- 芯片型号：{chip_name}
- 文档块数：{len(self.documents)}
- 导出时间：{datetime.now().strftime('%Y-%m-%d %H:%M:%S')}

---

*本文档由数据手册助手自动生成*
"""

            with open(filepath, 'w', encoding='utf-8') as f:
                f.write(md_content)

        else:
            filename = f"数据手册问答_{chip_name}_{timestamp}.docx"
            filepath = os.path.join(DATASHEET_OUTPUT, filename)

            doc = Document()
            doc.add_heading(chip_name, 0)
            p = doc.add_paragraph()
            p.add_run('技术问答记录').bold = True

            # 问题
            doc.add_heading('问题', 1)
            doc.add_paragraph(question)

            # 回答
            doc.add_heading('回答', 1)
            doc.add_paragraph(answer)

            # 元信息
            doc.add_paragraph()
            meta = doc.add_paragraph()
            meta_run = meta.add_run(f'\n芯片型号：{chip_name}\n')
            meta_run.font.size = Pt(9)
            meta_run.font.color.rgb = RGBColor(128, 128, 128)
            meta_run2 = meta.add_run(f'导出时间：{datetime.now().strftime("%Y-%m-%d %H:%M:%S")}')
            meta_run2.font.size = Pt(9)
            meta_run2.font.color.rgb = RGBColor(128, 128, 128)

            doc.save(filepath)

        return {
            "content": answer,
            "filename": filename,
            "filepath": filepath,
            "source": "数据手册助手"
        }

    def export_full_specs(self, format: str = "docx") -> Dict:
        """
        导出当前文档的所有技术规格
        """
        if not self.documents:
            return {
                "content": "没有已加载的文档",
                "source": "数据手册助手"
            }

        timestamp = int(time.time())
        chip_name = self.current_file or "Unknown"

        if format == "md":
            filename = f"{chip_name}_技术规格_{timestamp}.md"
            filepath = os.path.join(DATASHEET_OUTPUT, filename)

            # 收集所有内容
            all_content = []
            for doc in self.documents:
                all_content.append(doc['content'])

            md_content = f"""# {chip_name} - 完整技术规格

> 导出时间：{datetime.now().strftime('%Y-%m-%d %H:%M')}

---

## 文档概述

- 芯片型号：{chip_name}
- 内容块数：{len(self.documents)}
- 导出时间：{datetime.now().strftime('%Y-%m-%d %H:%M:%S')}

---

## 技术规格内容

"""

            for i, content in enumerate(all_content, 1):
                md_content += f"### 第 {i} 部分\n\n{content}\n\n---\n\n"

            md_content += """
## 使用说明

本文档由数据手册助手根据上传的数据手册自动提取生成。内容包括芯片的各项技术规格、电气参数、引脚定义等。

**注意事项：**
1. 本文档仅供参考，请以原始数据手册为准
2. 如有疑问，请查阅官方数据手册
3. 某些详细参数可能需要参考特定章节

---

*本文档由数据手册助手自动生成*
"""

            with open(filepath, 'w', encoding='utf-8') as f:
                f.write(md_content)

        else:
            filename = f"{chip_name}_技术规格_{timestamp}.docx"
            filepath = os.path.join(DATASHEET_OUTPUT, filename)

            doc = Document()
            doc.add_heading(chip_name, 0)
            doc.add_heading('完整技术规格', 1)

            # 元信息
            meta = doc.add_paragraph()
            meta.add_run(f'内容块数：{len(self.documents)}\n')
            meta.add_run(f'导出时间：{datetime.now().strftime("%Y-%m-%d %H:%M:%S")}')

            doc.add_paragraph()

            # 添加所有内容块
            for i, doc_item in enumerate(self.documents, 1):
                doc.add_heading(f'规格 {i}', 2)
                for para in doc_item['content'].split('\n'):
                    para = para.strip()
                    if para:
                        doc.add_paragraph(para)


            # Build content for return value
            content_text = chr(10).join(doc_item['content'] for doc_item in self.documents)

            doc.save(filepath)

        return {
            "content": content_text,
            "filename": filename,
            "filepath": filepath,
            "source": "数据手册助手"
        }


# 全局单例
datasheet_rag = DatasheetRAG()
